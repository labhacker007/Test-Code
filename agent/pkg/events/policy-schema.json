{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Policy Bundle",
  "description": "Signed policy bundle distributed from cloud to agents",
  "type": "object",
  "required": ["version", "policy_id", "issued_at", "expires_at", "rules"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^1\\.0$"
    },
    "policy_id": {
      "type": "string",
      "description": "Unique policy bundle identifier"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "mode": {
      "type": "string",
      "enum": ["strict", "permissive", "audit_only"],
      "default": "permissive"
    },
    "rules": {
      "type": "array",
      "items": {"$ref": "#/definitions/Rule"}
    },
    "allowlist": {
      "type": "object",
      "properties": {
        "packages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ecosystem": {"type": "string"},
              "name": {"type": "string"},
              "version_pattern": {"type": "string"}
            }
          }
        },
        "hashes": {
          "type": "array",
          "items": {"type": "string"}
        },
        "domains": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "denylist": {
      "type": "object",
      "properties": {
        "packages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ecosystem": {"type": "string"},
              "name": {"type": "string"},
              "reason": {"type": "string"},
              "reference": {"type": "string"}
            }
          }
        },
        "hashes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "value": {"type": "string"},
              "algorithm": {"type": "string"}
            }
          }
        },
        "domains": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "signature": {
      "type": "string",
      "description": "Ed25519 signature of canonical JSON (without this field)"
    }
  },
  "definitions": {
    "Rule": {
      "type": "object",
      "required": ["id", "name", "severity", "enabled", "conditions", "action"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "info"]
        },
        "enabled": {
          "type": "boolean"
        },
        "conditions": {
          "type": "array",
          "items": {"$ref": "#/definitions/Condition"}
        },
        "action": {
          "type": "string",
          "enum": ["allow", "deny", "alert", "escalate"]
        },
        "metadata": {
          "type": "object",
          "properties": {
            "mitre_attack": {"type": "array", "items": {"type": "string"}},
            "references": {"type": "array", "items": {"type": "string"}}
          }
        }
      }
    },
    "Condition": {
      "type": "object",
      "required": ["field", "operator", "value"],
      "properties": {
        "field": {
          "type": "string",
          "description": "JSONPath to event field (e.g., data.package_name)"
        },
        "operator": {
          "type": "string",
          "enum": ["equals", "contains", "matches", "in", "gt", "lt"]
        },
        "value": {
          "description": "Value to compare against (string, number, array)"
        },
        "case_insensitive": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
